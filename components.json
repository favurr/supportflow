{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "radix-vega",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "app/globals.css",
    "baseColor": "neutral",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "rtl": false,
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  },
  "menuColor": "default",
  "menuAccent": "subtle",
  "registries": {
    "@ibelick": {
      "url": "https://21st.dev/r/ibelick/{name}",
      "headers": {
        "X-API-Key": "${21stDevToken}"
      }
    },
    "@21stdev": {
      "url": "https://21st.dev/r/{name}",
      "headers": {
        "Authorization": "Bearer ${21stDevToken}"
      }
    },
    "@tailark": "https://tailark.com/r/{name}.json",
    "@prompt-kit": "https://www.prompt-kit.com/c/{name}.json",
    "@motion-primitives": "https://motion-primitives.com/c/{name}.json"
  }
}
